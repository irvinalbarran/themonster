# Mercado Pago Access Token (production or test)
MP_ACCESS_TOKEN=APP_USR-xxxx-xxxx-xxxx-xxxx

# Public URL for webhook callbacks (ngrok or your deployed server URL)
# Leave empty to disable callbacks
WEBHOOK_URL=

# Server port
PORT=3001

# Admin token for API authentication
# If set, all /api/* routes (except health, webhook, uploads) require:
#   header: x-admin-token: <token>
#   or query: ?token=<token>
# Leave empty to disable auth (development only)
ADMIN_TOKEN=
